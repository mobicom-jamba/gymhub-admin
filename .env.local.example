NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sono (Rico) whitelist: enable Vercel Static IPs on this project, then register those IPs with Sono.
# https://vercel.com/docs/connectivity/static-ips

# Pocket: optional floor for POST /api/payment/pocket (default 10000). Lower amounts often return 400 from Pocket.
# POCKET_MIN_AMOUNT_MNT=10000

# Pocket Payment Gateway
POCKET_OAUTH_HOST=sso.invescore.mn
POCKET_MERCHANT_HOST=service.invescore.mn/merchant
POCKET_REALM=invescore
POCKET_CLIENT_ID=your-pocket-client-id
POCKET_CLIENT_SECRET=your-pocket-client-secret
POCKET_TERMINAL_ID=your-pocket-terminal-id

# Carepay (merchant.carepay.mn → Салбар → Integration tab; create-invoice-phone flow)
CAREPAY_USERNAME=your-carepay-integration-username
CAREPAY_PASSWORD=your-carepay-integration-password
# CAREPAY_BASE_URL=https://merchant.carepay.mn/api/int
# CAREPAY_CALLBACK_URL=https://your-admin-domain/api/payment/carepay/callback

# MonPay mini-app (z-wallet.monpay.mn — register redirect + webhook with merchantservice@mobicom.mn)
MONPAY_CLIENT_ID=your-monpay-client-id
MONPAY_CLIENT_SECRET=your-monpay-client-secret
MONPAY_REDIRECT_URI=https://your-gymhub-domain/app/home
MONPAY_RECEIVER=partnerBayas
# MONPAY_BASE_URL=https://z-wallet.monpay.mn
# MONPAY_WEBHOOK_URL=https://your-admin-domain/api/payment/monpay/webhook
# MONPAY_WEBHOOK_SECRET=your-webhook-hmac-secret

# Firebase Cloud Messaging (push) — Firebase Console → Project settings → Service accounts → Generate new private key
# Paste the entire JSON as a single line, or use the split vars below.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"gymhub-a7d69",...}
# FIREBASE_PROJECT_ID=gymhub-a7d69
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@gymhub-a7d69.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
